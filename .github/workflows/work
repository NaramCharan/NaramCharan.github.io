name: Deploy Portfolio Website

on:
  push:
    branches: ["main"]
  workflow_dispatch:

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: "pages"
  cancel-in-progress: true

jobs:
  deploy:
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4

      - name: Setup GitHub Pages Environment Settings
        uses: actions/configure-pages@v5

      - name: Force Root Folder as Production Artifact
        uses: actions/upload-pages-artifact@v3
        with:
          path: '.'

      - name: Publish Direct to GitHub Pages Engine
        id: deployment
        uses: actions/deploy-pages@v4
